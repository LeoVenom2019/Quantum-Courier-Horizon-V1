{
  "name": "qch-game-project",
  "version": "0.1.0",
  "description": "QCH Game Project",
  "author": "Leonardo Dias",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean",
    "desktop:build": "next build && node scripts/prepare-desktop-standalone.js",
    "desktop:dev": "npm run desktop:build && electron .",
    "desktop:pack": "npm run desktop:build && electron-builder --win --dir",
    "desktop:dist": "npm run desktop:build && electron-builder --win nsis"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@hookform/resolvers": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.15.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.leonardodias.qch",
    "productName": "Quantum Courier Horizon",
    "directories": {
      "output": "dist-desktop-test"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "QCH-Setup-${version}.${ext}",
      "signAndEditExecutable": false,
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "electronDist": "node_modules/electron/dist",
    "disableAsarIntegrity": true,
    "asar": false
  }
}